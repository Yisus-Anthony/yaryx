generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  
}

model Product {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  folder        String
  coverPublicId String
  condition     String
  category      String
  price         Int

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([category])
  @@index([condition])
}